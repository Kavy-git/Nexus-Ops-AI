# ── NEXUS OPS — Environment Variables ─────────────────────────
# Copy to .env and fill in values

# Groq API key — FREE, no credit card needed
# Sign up at https://console.groq.com (takes 2 minutes)
# Free tier: 14,400 requests/day — more than enough
GROQ_API_KEY=gsk_your_key_here

# If you leave this blank, the smart rule-based planner activates automatically
# The app works 100% without any API key

# Execution mode
# "mock" = fast simulated responses (default, perfect for demo)
# "real" = actual LocalStack API calls
EXECUTION_MODE=mock

# LocalStack (AWS simulator) — auto-configured in Docker
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# Redis
REDIS_URL=redis://redis:6379

# Safety limits
MAX_INSTANCES_PER_USER=20
MAX_MONTHLY_BUDGET_USD=500
MAX_CONCURRENT_TASKS=10

# ── V2: Auth ────────────────────────────────────────────────────
# Set to "false" to disable auth entirely (local dev / hackathon demo)
# Set to "true" to require X-API-Key header on all requests
REQUIRE_AUTH=false

# Admin API key — bypasses user isolation, can see all tasks + metrics
# Change this to something secret in production
ADMIN_API_KEY=nexus-admin-key

# ── V2: Queue & Timeout ─────────────────────────────────────────
# How long (seconds) before a task is force-killed (default 30 min)
TASK_TIMEOUT_SECONDS=1800
